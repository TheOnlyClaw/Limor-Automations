{
  "name": "limor-automations",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "corepack npm -w apps/web run dev",
    "dev:web": "corepack npm -w apps/web run dev",
    "build": "corepack npm -w apps/web run build",
    "lint": "corepack npm -w apps/web run lint --if-present",
    "typecheck": "corepack npm -w apps/web exec tsc -b",
    "spec": "opsx-kit"
  },
  "devDependencies": {
    "openspec-kit": "^0.2.0"
  }
}
